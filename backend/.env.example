# ============================================================
# CareerPath AI — Backend Environment Variables
# Copy file này thành .env và điền giá trị thực vào
# KHÔNG commit file .env vào git!
# ============================================================

# ── Core App ──────────────────────────────────────────────
PROJECT_NAME="CareerPath AI"
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/careerpath"
# Tạo SECRET_KEY ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ──────────────────────────────────────────────
# Production: dùng PostgreSQL (asyncpg)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/careerpath"
# Development local (SQLite — KHÔNG dùng cho production):
# DATABASE_URL="sqlite+aiosqlite:///./careerpath.db"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Email (SMTP) ──────────────────────────────────────────
EMAILS_ENABLED=true
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAILS_FROM_EMAIL="noreply@careerpathai.com"
EMAILS_FROM_NAME="CareerPath AI"

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# QUAN TRỌNG: Chỉ đặt True khi dev local, KHÔNG bao giờ bật ở production
ALLOW_MOCK_LOGIN=false

# ── SePay Payment Gateway ─────────────────────────────────
SEPAY_API_TOKEN="your-sepay-api-token"
SEPAY_ACCOUNT_NUMBER="your-bank-account-number"
SEPAY_BANK_CODE="MB"
# Webhook secret để verify SePay callbacks — bắt buộc ở production
SEPAY_WEBHOOK_TOKEN="your-webhook-secret"

# ── Telegram Notifications ────────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-admin-chat-id"
